{
  "name": "resora",
  "version": "0.1.0",
  "private": true,
  "description": "Resora — India's Premium Resin Art Marketplace",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "firebase:emulators": "firebase emulators:start",
    "functions:build": "cd firebase/functions && npm run build",
    "functions:deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "firebase": "10.12.4",
    "framer-motion": "11.3.19",
    "gsap": "3.12.5",
    "react-hook-form": "7.52.1",
    "@hookform/resolvers": "3.9.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "tailwindcss": "3.4.7",
    "postcss": "8.4.40",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "firebase-admin": "12.3.0",
    "firebase-tools": "13.14.2",
    "vitest": "1.6.0",
    "@firebase/rules-unit-testing": "3.0.4"
  }
}
