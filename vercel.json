{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!api|_next|favicon\\.ico|sitemap\\.xml|robots\\.txt).*)",
      "destination": "/:path"
    }
  ]
}
