# =====================================================================
# RESORA — Environment Variables Template
# Per Build Prompt Phase 0, Step 2: "Environment variables (Firebase
# keys, future payment gateway keys) must be read from .env files that
# are gitignored — never hardcoded in source, never committed."
#
# Copy this file to .env.local (for local dev), .env.staging, or
# .env.production and fill in real values. NEVER commit the filled-in
# versions — see .gitignore.
# =====================================================================

# ---------------------------------------------------------------------
# Firebase Web SDK Config (client-side, safe to expose — these identify
# the project only; access control is enforced entirely by Firestore/
# Storage Security Rules, not by hiding these values)
# ---------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" only for local development against the Firebase Local
# Emulator Suite (firebase emulators:start). Never true in staging/prod.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# ---------------------------------------------------------------------
# Firebase Admin SDK (Cloud Functions runtime only — never exposed to
# the client, never prefixed NEXT_PUBLIC_)
# ---------------------------------------------------------------------
# In deployed Cloud Functions these are typically provided by the
# runtime's default service account rather than env vars; kept here for
# local emulator use with a service account key file.
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------
# Razorpay (§18.1 — Resora never stores card data; these keys live only
# in Cloud Functions secrets, set via `firebase functions:secrets:set`,
# NOT in this file for deployed environments. Included here only for
# local emulator testing.)
# ---------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Environment identifier — used for logging/monitoring context only,
# never for security decisions (those are Firestore rules + custom
# claims exclusively, per §16).
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_ENV=development
