# RESORA — .gitignore
# Per Build Prompt Phase 0, Step 2: "Environment variables ... must be
# read from .env files that are gitignored — never hardcoded in source,
# never committed."

# dependencies
node_modules/
firebase/functions/node_modules/
.pnp
.pnp.js

# next.js
.next/
out/
build/
dist/

# production
/build

# environment files — never committed, per Phase 0 Step 2
.env
.env.local
.env.development
.env.development.local
.env.staging
.env.staging.local
.env.production
.env.production.local
!.env.example

# firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
firestore-debug.log
pubsub-debug.log
database-debug.log
*.local.json
!firebase.json
!.firebaserc

# firebase functions build output
firebase/functions/lib/
firebase/functions/dist/

# testing
/coverage

# misc
.DS_Store
*.pem
Thumbs.db

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# editors
.vscode/*
!.vscode/extensions.json
.idea/

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel (not used for hosting per §18.1, but ignore if generated locally)
.vercel
